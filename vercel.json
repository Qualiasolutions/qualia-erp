{
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/shso",
      "destination": "https://shso.vercel.app/shso"
    },
    {
      "source": "/shso/:path*",
      "destination": "https://shso.vercel.app/shso/:path*"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/morning-email",
      "schedule": "0 6 * * 1-5"
    },
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 9 * * 5"
    },
    {
      "path": "/api/cron/uptime-check",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/attendance-report",
      "schedule": "30 21 * * 0-5"
    },
    {
      "path": "/api/cron/zoho-sync",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/cleanup-dry-run-reports",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/daily-brief",
      "schedule": "15 3 * * *"
    },
    {
      "path": "/api/cron/meeting-reminders",
      "schedule": "*/15 * * * *"
    }
  ]
}
