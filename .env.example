# =============================================================================
# Qualia Internal Suite — Required Environment Variables
# Copy to .env.local and fill in your values. Never commit .env.local.
# =============================================================================

# --- Supabase ---
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- App URL ---
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=

# --- AI ---
GOOGLE_GENERATIVE_AI_API_KEY=
OPENROUTER_API_KEY=

# --- Voice AI (VAPI) ---
VAPI_WEBHOOK_SECRET=

# --- Voice AI (ElevenLabs) ---
ELEVENLABS_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Cron / Webhooks ---
CRON_SECRET=
VERCEL_WEBHOOK_SECRET=

# --- Integrations (optional) ---
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# --- Vercel (auto-set in Vercel deployments) ---
# VERCEL_GIT_COMMIT_SHA=
# NODE_ENV=
# ANALYZE=
