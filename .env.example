# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# AI Chat - Groq API
# Get from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Optional: Modal VibeVoice TTS service URL
# Deploy with: modal deploy voice_service/main.py
# Falls back to browser TTS if not configured
NEXT_PUBLIC_VIBE_VOICE_URL=

# VAPI Voice Assistant Configuration
# Get these from your VAPI Dashboard at https://app.vapi.ai
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your-vapi-public-key
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-vapi-assistant-id  # Optional - uses inline config if not set
NEXT_PUBLIC_APP_URL=http://localhost:3000  # For webhook (change to production URL)
VAPI_WEBHOOK_SECRET=your-vapi-webhook-secret  # Secret for webhook authentication

# Sentry Error Tracking (optional but recommended for production)
# Get from https://sentry.io - Create Next.js project
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn
